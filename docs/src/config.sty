%================================
% CAJITA DE SOLUCION
%================================
% Forma de uso:
% \begin{sol}{}{}
% ...
% \end{sol}
\definecolor{mylenmabg}{HTML}{FFFAF8}
\definecolor{mylenmafr}{HTML}{983b0f}

\tcbuselibrary{theorems,skins,hooks}
\newtcbtheorem[no counter]{sol}{Solución}
{%
	enhanced,
	breakable,
	colback = mylenmabg,
	frame hidden,
	boxrule = 0sp,
	sharp corners,
	detach title,
	before upper = \tcbtitle\par\smallskip,
	coltitle = mylenmafr,
	fonttitle = \bfseries\sffamily,
	description font = \mdseries,
	separator sign none,
    left=0pt,
    right=0pt,
}
{th}

